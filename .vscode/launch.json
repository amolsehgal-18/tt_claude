    "version": "0.2.0",
    "configurations": [
        {
            "name": "Touchline Tantrum (Web)",
            "request": "launch",
            "type": "dart",
            "program": "touchline_tantrum/lib/main.dart"
        },
        {
            "name": "Touchline Tantrum (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}/touchline_tantrum"
        }
    ]
